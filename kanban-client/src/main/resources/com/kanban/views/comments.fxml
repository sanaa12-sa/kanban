<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.kanban.controller.CommentsController"
      spacing="14"
      style="-fx-background-color: #1e1e2e; -fx-padding: 24px;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="💬" style="-fx-font-size: 20px;"/>
        <Label fx:id="taskTitleLabel"
               text="Commentaires"
               style="-fx-text-fill: #cba6f7;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;"/>
    </HBox>

    <Separator style="-fx-background-color: #313244;"/>

    <!-- Zone commentaires scrollable -->
    <ScrollPane fitToWidth="true"
                prefHeight="280"
                style="-fx-background: #1e1e2e;
                       -fx-background-color: #1e1e2e;
                       -fx-border-color: #313244;
                       -fx-border-radius: 8px;">
        <VBox fx:id="commentsBox"
              spacing="10"
              style="-fx-padding: 10px; -fx-background-color: #1e1e2e;"/>
    </ScrollPane>

    <!-- Erreur -->
    <Label fx:id="errorLabel" text=""
           style="-fx-text-fill: #f38ba8; -fx-font-size: 12px;"/>

    <Separator style="-fx-background-color: #313244;"/>

    <!-- Saisie nouveau commentaire -->
    <VBox spacing="8">
        <Label text="Nouveau commentaire"
               style="-fx-text-fill: #a6adc8; -fx-font-size: 13px;"/>
        <TextArea fx:id="commentInput"
                  promptText="Écrivez votre commentaire ici..."
                  prefHeight="80"
                  style="-fx-background-color: #313244;
                         -fx-text-fill: #cdd6f4;
                         -fx-border-color: #45475a;
                         -fx-border-radius: 8px;
                         -fx-background-radius: 8px;
                         -fx-padding: 8px;"/>
    </VBox>

    <!-- Boutons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Fermer" onAction="#handleClose"
                style="-fx-background-color: #45475a;
                       -fx-text-fill: #cdd6f4;
                       -fx-background-radius: 8px;
                       -fx-padding: 10px 20px;
                       -fx-cursor: hand;"/>
        <Button text="📨 Envoyer" onAction="#handleSendComment"
                style="-fx-background-color: #89b4fa;
                       -fx-text-fill: #1e1e2e;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8px;
                       -fx-padding: 10px 20px;
                       -fx-cursor: hand;"/>
    </HBox>

</VBox>
