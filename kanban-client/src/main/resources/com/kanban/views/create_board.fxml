<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.kanban.controller.CreateBoardController"
      style="-fx-padding: 30; -fx-background-color: #1e1e2e;">

    <Label text="Nouveau Board" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;"/>

    <TextField fx:id="titleField" promptText="Titre du board"/>
    <TextField fx:id="descriptionField" promptText="Description"/>
    <TextField fx:id="colorField" promptText="Couleur (#89b4fa)"/>
    <ComboBox fx:id="visibilityBox" maxWidth="Infinity"/>

    <Label fx:id="errorLabel" styleClass="label-error"/>

    <HBox spacing="10">
        <Button text="Créer" onAction="#handleCreate" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button text="Annuler" onAction="#handleCancel" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>
</VBox>